---
import { marked } from 'marked';
import type { Hero as HeroProps } from '../types';
import Button from './Button.astro';

type Props = HeroProps;

const { title, text, actions } = Astro.props;
---

{
    (title || text || (actions && actions.length > 0)) && (
        <section class="mb-16 flex w-full flex-col gap-6 sm:mb-24">


            {/* Texto descriptivo */}
            {text && (
                <div
                    class="prose sm:prose-lg max-w-3xl"
                    set:html={marked.parse(text)}
                />
            )}

            {/* Botones */}
            {actions && actions.length > 0 && (
                <div class="flex flex-wrap gap-4">
                    {actions.map((action) => (
                        <Button href={action.href}>{action.text}</Button>
                    ))}
                </div>
            )}
        </section>
    )
}
