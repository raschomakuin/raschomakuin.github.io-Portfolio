---
import { getCollection } from 'astro:content';
import Button from '../components/Button.astro';
import Hero from '../components/Hero.astro';
import PostPreview from '../components/PostPreview.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../utils/data-utils';

const posts = (await getCollection('blog')).sort(sortItemsByDateDesc);
const featuredPosts = posts.filter(({ data }) => data.isFeatured);

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
const featuredProjects = projects.filter(({ data }) => data.isFeatured);
---

<BaseLayout description={siteConfig.description}>
    <Hero {...siteConfig.hero} />

<section class="my-20 sm:my-28">
    <h2 class="mb-12 font-serif text-2xl italic sm:text-4xl">
        Áreas de especialización
    </h2>

    <div class="grid gap-10 sm:grid-cols-3">
        
        <div class="rounded-2xl border p-6 transition hover:shadow-lg">
            <h3 class="mb-4 text-lg font-semibold">
                🧱 Arquitectura de Datos
            </h3>
            <p class="text-sm leading-relaxed text-gray-600">
                Diseño de Data Marts, modelado estrella, definición de granularidad
                e integración multi-fuente en entornos productivos como Azure,
                Databricks y bases Oracle.
            </p>
        </div>

        <div class="rounded-2xl border p-6 transition hover:shadow-lg">
            <h3 class="mb-4 text-lg font-semibold">
                ⚙ Automatización y Procesos
            </h3>
            <p class="text-sm leading-relaxed text-gray-600">
                Desarrollo de notebooks productivos, procesos ETL/ELT programados
                y automatización de flujos para reducir tareas manuales y
                garantizar consistencia operativa.
            </p>
        </div>

        <div class="rounded-2xl border p-6 transition hover:shadow-lg">
            <h3 class="mb-4 text-lg font-semibold">
                📊 Analítica Estratégica
            </h3>
            <p class="text-sm leading-relaxed text-gray-600">
                Definición de KPIs, construcción de modelos de medición
                y visualización ejecutiva en Power BI y Looker para
                soporte a decisiones institucionales.
            </p>
        </div>

    </div>
</section>
    {/*
{
        featuredProjects?.length > 0 && (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">Projects</h2>
                {featuredProjects.map((project) => (
                    <ProjectPreview project={project} class="mb-10 sm:mb-12" headingLevel="h3" />
                ))}
                <div class="mt-12 sm:mt-16">
                    <Button href="/projects">View All Projects</Button>
                </div>
            </div>
        )
    }
*/}
    {
        featuredPosts?.length > 0 && (
            <div class="mb-16 sm:mb-24">
                <h2 class="mb-12 font-serif text-xl italic sm:mb-16 sm:text-2xl">Proyectos técnicos</h2>
                {featuredPosts.map((post) => (
                    <PostPreview post={post} class="mb-10 sm:mb-12" headingLevel="h3" />
                ))}
                <div class="mt-12 sm:mt-16">
                    <Button href="/blog">Proyectos</Button>
                </div>
            </div>
        )
    }
</BaseLayout>
